# Azure Storage — connection string for the storage account used by this POC
# Run az-cli/provision.sh to create the resources and auto-generate .env,
# or fill in manually if you already have a storage account.
AZURE_STORAGE_ACCOUNT_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-account>;AccountKey=<your-key>;EndpointSuffix=core.windows.net

# Blob container for large uploads (created by provision.sh)
CONTAINER_LARGE_UPLOAD=large-uploads

# How long the SAS upload URL stays valid (hours)
SAS_EXPIRY_HOURS=1
