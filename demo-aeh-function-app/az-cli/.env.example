# ── Subscription ────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=

# ── Resource groups & location ───────────────────────────────────────────────
AZURE_RESOURCE_GROUP=rg-eh-fa
AZURE_NETWORK_RESOURCE_GROUP=rg-eh-fa-network
AZURE_REGION=switzerlandnorth

# ── Networking ───────────────────────────────────────────────────────────────
AZURE_VNET_NAME=vnet-eh-fa
AZURE_VNET_ADDRESS_PREFIX=10.0.0.0/16
AZURE_SUBNET_NAME=snet-eh-fa
AZURE_SUBNET_ADDRESS_PREFIX=10.0.1.0/24

# ── Storage ──────────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT=saehfa
AZURE_STORAGE_CONTAINER=container-eh-fa
AZURE_STORAGE_ACCOUNT_CONNECTION_STRING=

# ── Event Hub ────────────────────────────────────────────────────────────────
AZURE_EVENTHUB_NAMESPACE=evhns-eh-fa
AZURE_EVENTHUB_NAME=evh-eh-fa
EVENT_HUB_CONNECTION_STRING=

# ── Event Grid ───────────────────────────────────────────────────────────────
# (no extra vars needed — derived from storage + eventhub above)

# ── Function App ─────────────────────────────────────────────────────────────
AZURE_APP_SERVICE_PLAN=asp-eh-fa
AZURE_FUNC_APP_NAME=func-eh-fa
